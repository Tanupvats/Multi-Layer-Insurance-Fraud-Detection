# Keep the build context small and prevent secrets sneaking in.

.git/
.github/
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/

# Runtime state
outputs/
audit.db*
*.log

# Weights & data — mounted at runtime, not baked in
models/*.pt
models/*.pth
datasets/

# Secrets
.env
.env.*
!.env.example

# Docs / images that balloon the context
*.png
*.jpg
*.gif

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
