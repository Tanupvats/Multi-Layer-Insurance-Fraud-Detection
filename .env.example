

# --- App ---
AUTOSHIELD_APP_ENV=dev                     # dev | staging | prod
AUTOSHIELD_LOG_LEVEL=INFO
AUTOSHIELD_LOG_JSON=false                  # true for structured JSON logs

# --- Compute ---
AUTOSHIELD_DEVICE=auto                     # auto | cuda | cpu

# --- Paths ---
AUTOSHIELD_MODELS_DIR=models
AUTOSHIELD_OUTPUTS_DIR=outputs
AUTOSHIELD_MODEL_CONFIG_PATH=configs/model.yaml

# --- Weight filenames (resolved inside MODELS_DIR unless absolute) ---
AUTOSHIELD_POSE_WEIGHTS=car_pose_v1.pth
AUTOSHIELD_SIAMESE_WEIGHTS=siamese_identity.pth
AUTOSHIELD_PARTS_SEG_WEIGHTS=parts_segmenter.pt
AUTOSHIELD_CAR_SEG_WEIGHTS=yolo11n-seg.pt

# --- Feature flags ---
AUTOSHIELD_ALLOW_MODEL_DOWNLOAD=true       # first-run HF Hub / Ultralytics fetch
AUTOSHIELD_SAVE_VISUALIZATIONS=true
AUTOSHIELD_STRICT_INPUT=true               # true = raise on bad image; false = INCONCLUSIVE

# --- API ---
AUTOSHIELD_API_MAX_UPLOAD_MB=15
AUTOSHIELD_AUDIT_DB_PATH=audit.db
AUTOSHIELD_CORS_ALLOW_ORIGINS=*            # comma-separated or "*"
